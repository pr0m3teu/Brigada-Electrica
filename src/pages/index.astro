---
import MainLayout from '../layouts/MainLayout.astro'
import Trust from '../components/Trust.astro'
import DeCeNoi from "../components/DeCeNoi.astro"
import "../styles/global.css"
import { Image } from 'astro:assets'

import lightBulbSvg from "../assets/svg/lighbulb.svg"
import phonePng from "../assets/png/phone.png"
import prizaPng from "../assets/jpg/poza-priza.jpg"
import checkPng from "../assets/png/check.png"
import boltSvg from "../assets/svg/bolt.svg"
import smartlightPng from "../assets/png/smart-light.png"
import smarthomePng from  "../assets/png/smart-home.png"
import smarttabletPng from "../assets/jpg/smart-tablet.jpg"

import ServiciiCard from '../components/ServiciiCard.astro'


const description = "Brigada Electrică – instalații electrice, reparații, mentenanță și soluții smart home în Iași. Intervenție rapidă, siguranță garantată. Sună acum: 0740 543 785."

const benefits = {
  reparatii: ["Diagnostică scurcircuite", "Schimbare tablou electric vechi", "Prize, întrerupătoare, corpuri de iluminat"],
  smartLight: ["Control lumini din telefon", "Păstrezi întrerupătoarele existente", "Adăugăm întrerupătoare wireless"],
  smartHome: ["Lumini + termostat", "Senzori prezență umană", "Control vocal"]
}
---

<MainLayout pageDescription={description}>
    <title slot="title">Brigada Electrică - Instalații Electrice în Iași</title>

    <section id="home-title" 
      class="bg-main-blue-950 bg-[url(../assets/jpg/bg.jpg)] bg-center bg-cover bg-blend-overlay min-h-[50vh]
      pt-24 pb-20 px-5 text-center scroll-m-30 space-y-6 
      lg:py-16 lg:px-12 md:text-left" >

      <h1 class="font-montserrat font-bold text-main-white section-header-size mb-6 lg:leading-18">
        Instalații electrice și case smart, 
        fără șantier, fără mizerie, fără bătaie de cap
      </h1>
      
      <p class="font-semibold mb-8 text-lg md:text-xl lg:text-2xl lg:w-2/3 text-main-blue-400">
        De la o priză defectă la o casă complet automatizată — 
        rezolvăm totul sigur și rapid.
      </p>

      <!-- Butoane hero -->
      <div class="w-fit mx-auto items-center place-items-center gap-4 mt-5 md:flex md:gap-6 lg:mx-0">
        <button id="hero-button1" class="text-main-white bg-main-blue-700 
          py-2 px-6 text-lg lg:py-3.5 w-full lg:text-xl rounded-3xl
          flex items-center justify-center  
          cursor-pointer md:w-fit lg:btn-primary">

          <img src={lightBulbSvg.src} fetchpriority="low" alt="lightbulb icon" class="w-5 font-medium md:w-6">
          <span class="ml-1 lg:ml-1.5 font-medium"> Vreau o casă smart </span>      
        </button>      

        <button class="text-main-white bg-main-gold hidden
          py-2 px-3 text-lg lg:py-3.5 lg:px-6 lg:text-xl rounded-3xl 
          md:flex items-center justify-center  
          cursor-pointer md:w-fit btn-primary"
          onclick="window.location.href='tel:+40740543785'">

          <img src={phonePng.src} fetchpriority="low" alt="telefon icon" class="w-4.5 md:w-6">
          <span class="ml-1 lg:ml-1.5 font-medium"> Ai o urgență? Sună acum! </span>      
        </button>
      
      </div>
    </section>

	<Trust/>

<!-- Problemă → Agitare Section -->
    <section class="bg-main-blue-950 px-6 py-16 text-center space-y-6 md:py-20 lg:px-12 md:text-left">
      <p class="bg-main-gold/20 w-fit mx-auto md:mx-0 text-main-gold font-semibold text-md py-1 px-4 rounded-2xl  ">
        Îți sună cunoscut?
      </p>

      <h2 class="font-bold text-main-white section-header-size mb-4  ">
        Tabloul electric e vechi și nu-ți mai inspiră încredere?
      </h2>

      <p class="text-gray-300 text-lg md:text-xl lg:text-2xl lg:w-2/3 mb-8 leading-relaxed  ">
        Prizele se încălzesc, siguranțele sar des, fire vechi ascunse prin pereți de care nimeni nu mai știe nimic.
        Nu e doar incomod — <span class="font-bold text-main-white">e un risc real de incendiu și scurtcircuit.</span>
      </p>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8  ">
        <li class="flex items-center gap-3 bg-main-blue-800/60 p-4 rounded-lg">
          <i class="fa-solid fa-triangle-exclamation text-main-gold text-xl shrink-0"></i>
          <p class="text-main-white text-sm md:text-base">Siguranțe care sar des</p>
        </li>
        <li class="flex items-center gap-3 bg-main-blue-800/60 p-4 rounded-lg">
          <i class="fa-solid fa-fire text-main-gold text-xl shrink-0"></i>
          <p class="text-main-white text-sm md:text-base">Prize calde sau pârâite</p>
        </li>
        <li class="flex items-center gap-3 bg-main-blue-800/60 p-4 rounded-lg">
          <i class="fa-solid fa-bolt text-main-gold text-xl shrink-0"></i>
          <p class="text-main-white text-sm md:text-base">Tablou electric vechi, nemodernizat</p>
        </li>
        <li class="flex items-center gap-3 bg-main-blue-800/60 p-4 rounded-lg">
          <i class="fa-solid fa-house-circle-exclamation text-main-gold text-xl shrink-0"></i>
          <p class="text-main-white text-sm md:text-base">Instalație fără autorizație ANRE?</p>
        </li>
      </ul>

      <p class="text-main-white text-lg md:text-xl font-semibold  ">
        Rezolvăm asta rapid, fără șantier și fără mizerie — vezi mai jos cum.
      </p>
    </section>
  <!-- TODO: Add icons to each li -->
    <!-- Instalații Electrice section -->
    <main class="px-6 py-20 space-y-6 grid gap-4 md:grid-cols-2 md:grid-rows-1 md:px-7 lg:pl-12 lg:pr-8">
      <div class="h-full">
        <h2 class="font-bold section-header-size mb-6  ">
          Instalații Electrice <span class="text-main-gold">Sigure & Durabile</span>
        </h2>
        <p class="text-md mb-8 text-gray-600 leading-relaxed lg:pr-4 md:text-lg lg:text-xl  ">
          Siguranța casei tale nu este un loc pentru improvizații. 
          Executăm lucrări electrice conform normativelor în vigoare, folosind materiale premium și scule profesionale. 
          Fără fire atârnate, fără mizerie, fără riscuri.
        </p>
        
        <ul class="rounded-2xl grid grid-rows-4 gap-2 mb-6 px-2 md:px-4 lg:px-6 md:grid-cols-2 md:grid-rows-2 md:ml-0 md:justify-center   ">
          <li class="my-2">
            <h4 class="text-md lg:text-xl font-semibold ">Tablouri electrice</h4>
            <p class="text-sm text-gray-600 leading-relaxed">Schimbare siguranțe & modernizare panou.</p>
          </li>
          <li class="my-2">
            <h4 class="text-md lg:text-xl font-semibold">Corpuri de Iluminat</h4>
            <p class="text-sm text-gray-600 leading-relaxed">Montaj lustre, aplice și benzi LED.</p>
          </li>
          <li class="my-2">
            <h4 class="text-md lg:text-xl font-semibold">Prize & întrerupătoare</h4>
            <p class="text-sm text-gray-600 leading-relaxed">Montaj, mutare sau înlocuire.</p>
          </li>
          <li class="my-2">
            <h4 class="text-md lg:text-xl font-semibold">Diagnosticare</h4>
            <p class="text-sm text-gray-600 leading-relaxed">Identificare și reparație scurtcircuite.</p>
          </li>
        </ul>
        <div class="flex items-center justify-center  ">
          <a href="https://wa.me/40740543785" 
          class="inline-flex justify-center items-center gap-1 px-8 py-4 border-2 
              border-green-500 text-green-600 font-bold rounded-xl hover:bg-green-50 transition-colors">
            <i class="fa-brands fa-whatsapp text-xl text-green-600"></i>
            Scrie-ne pe WhatsApp
          </a>
        </div>
      </div>

      <div class="h-full w-full relative flex justify-center min-h-100 rounded-2xl overflow-hidden shadow-xl group   ">
        <Image src={prizaPng} alt="eletrician lucrand profesional in iasi" class="absolute rounded-4xl shadow-2xl duration-700 h-full w-full object-cover transition  group-hover:scale-105 inset-0"/> 
        <div class="absolute bottom-6 left-6 right-6 bg-white/95 backdrop-blur-sm p-4 rounded-xl shadow-lg border-l-4 border-brand-red">
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center text-brand-red shrink-0">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>

                <div class="absolute inset-0 bg-linear-to-t to-transparent"></div>

                <div>
                    <p class="font-semibold text-main-blue text-sm">Ai rămas fără curent?</p>
                    <p class="text-xs font-light text-gray-500">Intervenim în regim de urgență în Iași.</p>
                </div>
            </div>
        </div>
      </div>
    </main>

	<!-- Oferte servicii -->
    <section class="py-20 space-y-6 px-6 scroll-m-16 bg-main-white lg:px-20" id="servicii">
      <!-- Ce oferim -->
      <div class="flex flex-1 items-center justify-center mb-10">
        <p class=" bg-main-blue-200 w-fit text-main-blue-700 font-semibold text-md py-1 px-4 rounded-2xl">
          Ce oferim
        </p>
      </div>

      <h2 class="text-main-blue text-center font-semibold mb-6   section-header-size">Servicii și pachete</h2>
      <p class="mb-8 text-2xl text-center text-gray-500   lg:text-3xl">Alege soluția potrivită pentru nevoile tale</p>

      <div class="grid grid-rows-3 gap-y-16 md:px-6 lg:grid-cols-3 lg:grid-rows-1 lg:gap-12 ">
      
        <!-- CARD 1 -->
        <ServiciiCard benefits={benefits.reparatii} >
            <Image slot="icon" src={boltSvg} alt="fulger" loading="lazy" class="mx-auto lg:mx-0 w-10 h-10 p-3 mb-2.5 box-content bg-secondary-yellow/60 rounded-2xl"/>
            <h3 slot="title" class="title-servicii-card">Reparații Electrice</h3>
            <p slot="description" class="description-servicii-card">Pentru problemele urgente.</p>
        </ServiciiCard>

        <!-- CARD 2 -->
        <div class="rounded-xl shadow-2xl border-2 border-secondary-blue/60 flex flex-col h-full relative">

          <div class="absolute top-0 right-0 bg-secondary-blue text-main-white px-4 py-1 text-sm rounded-bl-lg rounded-tr-xl">
              <p class="font-poppins">Cel mai popular</p>
          </div>


          <ServiciiCard benefits={benefits.smartLight}>
              <Image slot="icon" src={smartlightPng} alt="smart light" loading="lazy" class="mx-auto lg:mx-0 w-10 h-10 p-3 mb-2.5 box-content bg-light-blue rounded-2xl"/>
              <h3 slot="title" class="title-servicii-card">Iluminat Inteligent</h3>
              <p slot="description" class="description-servicii-card">Ideal pentru dormitor sau living.</p>
          </ServiciiCard>
        </div>
            
        <!-- CARD 3 -->
        <ServiciiCard benefits={benefits.smartHome}>
            <Image slot="icon" src={smarthomePng} loading="lazy" alt="smart home" class="mx-auto lg:mx-0 w-10 h-10 p-3 mb-2.5 box-content bg-light-blue/60 rounded-2xl"/>
            <h3 slot="title" class="title-servicii-card">Casă Complet Automatizată</h3>
            <p slot="description" class="description-servicii-card">Control total + economie de energie.</p>
        
        </ServiciiCard>
      
      </div>
    </section>

	<DeCeNoi/>

	    <!-- Smart Lighting Section  -->
    <section  class="px-6 py-20 space-y-6 bg-main-white grid gap-10 md:gap-8 md:grid-cols-2 md:grid-rows-1 md:px-7 lg:pl-12 lg:pr-8">
      <div class="h-full">
        <h2 class="font-semibold mb-6 section-header-size">
          Cum facem casa Smart fără să renovăm tot?
        </h2>
        <p class="text-gray-600 text-xl leading-relaxed mb-8 ">
          Majoritatea oamenilor cred că automatizarea înseamnă șantier și cabluri noi. 
          <span class="font-bold">Fals.</span> <br>
          Folosim relee wireless de ultimă generație, montate invizibil în spatele prizelor sau întrerupătoarelor tale actuale.
        </p>
        
        <ul class="grid sm:grid-cols-2 lg:grid-cols-2 gap-4 max-w-5xl mx-auto">
          <li class="flex items-center gap-3 bg-white p-4 rounded-lg shadow">
            <img src={checkPng.src} alt="bifa" loading="lazy" class="w-5 ml-2">
            <p>Instalare invizibilă</p>
          </li>
          <li class="flex items-center gap-3 bg-white p-4 rounded-lg shadow">
            <img src={checkPng.src} alt="bifa" loading="lazy" class="w-5 ml-2">
            <p>Controlezi luminile din telefon sau voce</p>
          </li>
          <li class="flex items-center gap-3 bg-white p-4 rounded-lg shadow">
            <img src={checkPng.src} alt="bifa" loading="lazy" class="w-5 ml-2">
            <p>Montaj rapid ~30 minute / cameră</p>
          </li>
          <li class="flex items-center gap-3 bg-white p-4 rounded-lg shadow">
            <img src={checkPng.src} alt="bifa" loading="lazy" class="w-5 ml-2">
            <p>Testare și instruire completă</p>
          </li>
        </ul>
      </div>
      <div class="h-full w-full relative flex justify-center min-h-100 rounded-2xl overflow-hidden shadow-xl group ">
        <Image src={smarttabletPng} alt="smart-home" 
        class="absolute rounded-4xl shadow-2xl h-full w-full object-cover transition duration-700 group-hover:scale-105 inset-0"/>
        
        <div class="absolute bottom-6 left-6 right-6 bg-white/95 backdrop-blur-sm p-2 md:p-4 rounded-xl shadow-lg border-l-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-main-blue-100 rounded-full flex items-center justify-center text-brand-red shrink-0">
                    <i class="fa-solid fa-lightbulb"></i>
                </div>

                <div class="absolute inset-0 bg-linear-to-t from-main-blue-100/20 to-transparent"></div>

                <div>
                    <p class="font-semibold text-main-blue text-sm">Vrei o casă smart?</p>
                    <p class="text-xs font-light text-gray-500">Oferim soluții de automatizări fără mizerie, fără șantier.</p>
                </div>
            </div>
        </div>
      </div>
    </section>

    

    <!-- Last section -->
    <section id="smart-home-section" class="bg-linear-to-r from-main-blue-500 to-main-blue-700 text-main-white flex items-center justify-center flex-col px-6 py-20 space-y-6 lg:px-10 scroll-m-20">
      <h2 class="text-center font-semibold section-header-size mb-6">Pregătit să-ți transformi casa?</h2>
      <p class="text-2xl max-w-4xl text-center mb-8">Sună acum pentru o evaluare gratuită. Îți spunem exact ce se poate face și cât costă, fără angajamente.</p>
    
      <div class="w-[80%] flex flex-col justify-center lg:flex-row gap-3 mt-8">
          <button class="text-main-white bg-main-gold 
              py-2 px-1.5 text-md lg:py-3 lg:px-3 lg:text-xl rounded-2xl 
              flex items-center justify-center 
              cursor-pointer md:w-fit btn-primary border-main-white border-2"
              onclick="window.location.href='tel:+40740543785'">

              <img src={phonePng.src} alt="telefon icon" loading="lazy" class="w-4.5 md:w-6">
              <span class="ml-1 lg:ml-1.5 font-semibold">0740 543 785</span>      
          </button>
          <!-- TODO: Fix animation color change and what not -->
          <div class="flex items-center justify-center btn-primary">
            <a href="https://wa.me/40740543785" 
            class="h-full w-full inline-flex justify-center items-center gap-1 px-2 py-2 lg:px-4 lg:py-2 border-2 text-md lg:text-xl
                bg-green-600 text-main-white font-semibold rounded-2xl hover:bg-green-500 transition-colors">
              <i class="not-md:hidden fa-brands fa-whatsapp text-md lg:text-xl" ></i>
              WhatsApp
            </a>
          </div>
        </div>
    
    </section>
</MainLayout>
