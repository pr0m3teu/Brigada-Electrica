---
import MainLayout from "../layouts/MainLayout.astro"
import Trust from "../components/Trust.astro"
import "../styles/global.css"
import { Image } from "astro:assets"
import phonePng from "../assets/png/phone.png"

const pageDescription = "Servicii complete de electrician în Iași: instalații electrice noi, reparații tablouri electrice, mentenanță și case inteligente. Cere ofertă gratuită.";

---

<MainLayout pageDescription={pageDescription}>

    <section id="servicii-title" 
        class="scroll-mt-20 px-6 text-center pt-24 pb-20 space-y-6 min-h-[45vh]
        lg:px-12  bg-[url(../assets/jpg/bg.jpg)] 
        bg-main-blue bg-center bg-cover bg-blend-overlay">

        <p class="text-main-blue-400 font-semibold text-sm uppercase  mb-4 animation-fade-in duration-300">
            Servicii
        </p>
        <h1 class="font-bold text-main-white section-header-size mb-6 scroll-mt-16 lg:leading-18">
          Instalații electrice sigure. <br>Soluții smart pentru casa ta.
        </h1>
        <p class="font-semibold text-lg md:text-xl lg:text-2xl text-main-blue-400 mb-8">
          De la reparații urgente și tablouri electrice până la automatizări smart home. <br class="hidden lg:block"> Intervenim rapid în Iași și împrejurimi.
        </p>
    </section>

    <Trust/>

    <main id="serivicii-description" class="my-10  bg-main-white rounded-2xl">
      
      <div class="servici-section bg-main-white">
        <h3 class="servici-title">Urgențe Electrice</h3>
        <p class="servici-description">
          O problemă electrică nu așteaptă un program de lucru. 
          Venim rapid pentru orice situație care îți pune în pericol siguranța sau afacerea
        </p>

        <ul>
          <li class="servici-problem">
            <span class="font-medium text-main-gold">-</span> Pene de curent și scurtcircuite
          </li>
          <li class="servici-problem">
            <span class="font-medium text-main-gold">-</span> Miros de ars sau scântei la prize/tablou
          </li>
          <li class="servici-problem">
            <span class="font-medium text-main-gold">-</span> Depanare rapidă la domiciliu sau sediu firmă
          </li>
          <li class="servici-problem">
            <span class="font-medium text-main-gold">-</span> Evaluare gratuită a cauzei defecțiunii
          </li>
        </ul>
        <a href="tel:+40740543785" class="servici-cta bg-main-blue-800 hover:bg-main-blue-700">Sună pentru urgențe →</a>
      </div>
    
      <div class="bg-[#EEEFEA] servici-section">
        <h3 class="servici-title">Instalații Electrice Complete</h3>
        <p class="servici-description">
          Realizăm instalația electrică de la zero sau o modernizăm complet, 
          cu materiale de calitate și respectarea normativelor în vigoare.
        </p>

        <ul>
          <li class="servici-problem">
            <span class="font-medium text-main-gold">-</span> Case noi și extinderi
          </li>
          <li class="servici-problem">
            <span class="font-medium text-main-gold">-</span> Renovări complete de instalație
          </li>
          <li class="servici-problem">
            <span class="font-medium text-main-gold">-</span> Spații comerciale și birouri
          </li>
        </ul>
        <a href="tel:+40740543785" class="servici-cta bg-main-gold hover:opacity-95">Cere ofertă gratuită →</a>
      </div>
      
      <div class="servici-section">
        <h3 class="servici-title">Tablouri Electrice și Protecție</h3>
        <p class="servici-description">
          Un tablou electric modern e prima linie de apărare a locuinței tale. 
          Îl actualizăm astfel încât să facă față consumului actual, în siguranță.
        </p>

        <ul>
          <li class="servici-problem">
            <span class="font-medium text-main-gold">-</span> Modernizare și extindere tablou
          </li>
          <li class="servici-problem">
            <span class="font-medium text-main-gold">-</span> Siguranțe automate și diferențiale
          </li>
          <li class="servici-problem">
            <span class="font-medium text-main-gold">-</span> Împământare conformă normativelor
          </li>
          <li class="servici-problem">
            <span class="font-medium text-main-gold">-</span> Protecție la supratensiune
          </li>
        </ul>
        <a href="tel:+40740543785" class="servici-cta bg-main-blue-800 hover:bg-main-blue-700">Sună pentru urgențe →</a>
      </div>

      <div class="servici-section bg-main-blue-800">
        <h3 class="servici-title text-main-white">Case Inteligente</h3>
        <p class="servici-description text-gray-300">
          Transformăm locuința ta într-un spațiu inteligent: 
          lumini, prize, senzori și climatizare controlate de pe telefon sau prin comenzi vocale.
        </p>

        <ul class="text-main-white">
          <li class="servici-problem text-main-white">
            <span class="font-medium text-main-gold">-</span> Automatizare iluminat și prize
          </li>
          <li class="servici-problem text-main-white">
            <span class="font-medium text-main-gold">-</span> Senzori de mișcare, fum și inundație
          </li>
          <li class="servici-problem text-main-white">
            <span class="font-medium text-main-gold">-</span> Control centralizat din aplicație
          </li>
          <li class="servici-problem text-main-white">
            <span class="font-medium text-main-gold">-</span> Compatibil cu sisteme existente
          </li>
        </ul>
        <a href="tel:+40740543785" class="servici-cta bg-main-gold">Transformă-ți casa →</a>
      </div>

      <div class="servici-section">
        <h3 class="servici-title">Iluminat Rezidențial și Comercial</h3>
        <p class="servici-description">
          Un iluminat bine gândit schimbă complet felul în care se simte un spațiu — și reduce factura la curent
        </p>

        <ul>
          <li class="servici-problem">
            <span class="font-medium text-main-gold">-</span> Iluminat LED eficient energetic
          </li>
          <li class="servici-problem">
            <span class="font-medium text-main-gold">-</span> Iluminat exterior și de curte
          </li>
          <li class="servici-problem">
            <span class="font-medium text-main-gold">-</span> Amenajări pentru spații comerciale
          </li>
        </ul>
        <a href="tel:+40740543785" class="servici-cta bg-main-blue-800 hover:bg-main-blue-700">Sună pentru urgențe →</a>
      </div>
    </main>

    <include src="partials/de-ce-noi.html"></include>


    <section id="proces" class="bg-main-white text-main-blue-800 py-20 md:py-24 max-w-7xl mx-auto px-5 md:px-8">
      <h2 class=" font-bold text-3xl md:text-4xl mb-14 max-w-xl">
        Cum decurge o lucrare, pas cu pas
      </h2>

      <div class="grid md:grid-cols-4 gap-8 md:gap-2">
        <div class="md:pr-6 relative">
          <span class="font-mono text-main-gold text-sm">01</span>
          <h3 class="font-poppinss font-semibold text-lg mt-2 mb-2">Ne contactezi</h3>
          <p class="text-ink-soft text-sm leading-relaxed">Suni sau completezi formularul de pe site, descriind problema sau proiectul.</p>
        </div>
        
       <div class="md:px-6 relative">
          <span class="font-mono text-main-gold text-sm">02</span>
          <h3 class="font-poppins font-semibold text-lg mt-2 mb-2">Programăm intervenția</h3>
          <p class="text-ink-soft text-sm leading-relaxed">Stabilim o dată sau, pentru urgențe, ne deplasăm în cel mai scurt timp.</p>
        </div>
        
        <div class="md:px-6 relative">
          <span class="font-mono text-main-gold text-sm">03</span>
          <h3 class="font-poppins font-semibold text-lg mt-2 mb-2">Executăm lucrarea</h3>
          <p class="text-ink-soft text-sm leading-relaxed">Lucrăm curat, respectăm oferta stabilită și te ținem la curent.</p>
        </div>
      </div>
    </section>

    <!-- Last section -->
    <section id="last-section" class="bg-linear-to-r from-main-blue-500 to-main-blue-700 text-main-white flex items-center justify-center flex-col px-6 py-20 space-y-6 lg:px-10 scroll-m-20">
      <h2 class="text-center font-semibold max-w-5xl section-header-size mb-6">Ai o problemă electrică sau un proiect în minte?</h2>
      <p class="text-2xl text-center mb-8">
        Trimite-ne detalii despre situația ta și îți recomandăm soluția potrivită. <br>
        Intervenim pentru reparații, instalații electrice și soluții smart home în Iași.
      </p>
    
      <div class="w-[80%] flex flex-col justify-center lg:flex-row gap-3 mt-8">
          <button class="text-main-white bg-main-gold 
              py-2 px-1.5 text-md lg:py-3 lg:px-3 lg:text-xl rounded-2xl 
              flex items-center justify-center 
              cursor-pointer md:w-fit btn-primary border-main-white border-2"
              onclick="window.location.href='tel:+40740543785'">

              <Image src={phonePng} alt="telefon icon" class="w-4.5 md:w-6"/>
              <span class="ml-1 lg:ml-1.5 font-semibold">0740 543 785</span>      
          </button>
          <!-- TODO: Fix animation color change and what not -->
          <div class="flex items-center justify-center btn-primary">
            <a href="https://wa.me/40740543785" 
            class="h-full w-full inline-flex justify-center items-center gap-1 px-2 py-2 lg:px-4 lg:py-2 border-2 text-md lg:text-xl
                bg-green-600 text-main-white font-semibold rounded-2xl hover:bg-green-500 transition-colors">
              <i class="not-md:hidden fa-brands fa-whatsapp text-md lg:text-xl"></i>
              WhatsApp
            </a>
          </div>
        </div>
    </section>
    
</MainLayout>
