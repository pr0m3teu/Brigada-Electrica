---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { Font } from "astro:assets";

const { pageDescription } = Astro.props;

---

<!doctype html>
<html lang="ro">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<meta name="description" content={pageDescription}>
		
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		<link rel="manifest" href="/site.webmanifest">

		
		<!-- Google tag (gtag.js) -->
		<script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-X5PNHMHTXD"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-X5PNHMHTXD');
		</script>
		
		
		
		<!-- Fontawesome icons -->
		<script src="https://kit.fontawesome.com/c1f0767583.js" crossorigin="anonymous"></script>

		<title>Brigada Electrică - Instalații Electrice în Iași</title>

		<Font cssVariable="--font-montserrat"/>
		<Font cssVariable="--font-poppins"/>
	</head>

	<body class="bg-main-white">
		<Navbar/>
			<slot/>
		<Footer/>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}
</style>


