---
import "../styles/hamburger.css";
import Logo from "../assets/png/Logo-Shield-White.png"
import { Image } from "astro:assets";
---

<header class="bg-main-blue/97 overflow-hidden sticky top-0 z-10">
    <nav class="hidden px-4 py-4 md:py-4.5 lg:px-8 md:flex justify-between items-center">
    <!-- Logo -->
    <a href="/">
    <div class="flex items-center">
        <Image src={Logo} alt="logo" fetchpriority="high"
        class="w-6 md:w-8 lg:w-10 h-full"/>
        <h2 class="text-lg md:text-xl lg:text-2xl text-main-white font-bold ml-1.5 cursor-pointer">Brigada Electrică</h2>
    </div>
    </a>

    <ul class="not-md:hidden flex items-center text-lg font-medium">
        <li class="text-main-white mx-3 cursor-pointer hover:text-gray-300"><a href="/">Acasă</a></li>
        <li class="text-main-white mx-3 cursor-pointer hover:text-gray-300"><a href="/servicii">Servicii</a></li>
        <li id="contact" class="text-main-white mx-3 cursor-pointer hover:text-gray-300"><a href="/contact">Contact</a></li>
        <!-- <li class="text-main-white mx-1.5 cursor-pointer hover:text-gray-300">Lucrari</li> -->
    </ul>

    <div class="flex items-center justify-center">
        <a href="https://wa.me/40740543785" 
        class="inline-flex justify-center items-center gap-1 lg:px-4 lg:py-2 border-2 md:text-md lg:text-lg btn-primary
            border-green-600 text-green-600 font-semibold lg:font-bold rounded-xl hover:shadow-2xl transition-colors">
        <i class="fa-brands fa-whatsapp lg:text-xl"></i>
        Scrie pe WhatsApp
        </a>
    </div>
    </nav>

    <!-- Hamburger menu mobile -->
    <nav class="bg-main-blue nav-mobile flex md:hidden px-4 py-3.5 justify-between items-center">
    <a href="/" class="link">
        <div class="flex items-center">
        <Image id="nav-logo" class="w-10 h-full" fetchpriority="high" loading="eager" src={Logo} alt="logo"/>
        <h2 class="text-xl text-main-white font-bold ml-1.5 cursor-pointer">Brigada Electrică</h2>
        </div>
    </a>
    <label for="checkbox" role="navigation" class="hamburger-menu">
        <input type="checkbox" name="check" id="checkbox"/>
    </label>
    </nav>
    <aside class="sidebar">
        <div class="h-full">
            <ul class="h-full text-center flex pb-3 pt-6 flex-col font-medium px-5">
                <li class="w-full mx-auto">
                    <a href="/"><p class="my-4 mx-auto text-2xl text-center">Acasă</p></a>
                </li>

                <li class="w-full mx-auto text-base">
                    <a href="/servicii"> <p class="my-4 mx-auto text-2xl text-center">Servicii</p></a>
                </li>
                
                <li class="w-full mx-auto text-base">
                    <a href="/contact"> <p class="my-4 mx-auto text-2xl text-center">Contact</p></a>
                </li>

                <li class="w-fit mx-auto mt-auto">
                <div class="mt-8">
                    <a href="https://wa.me/40740543785" 
                    class="inline-flex justify-center text-2xl items-center gap-2 px-2 py-3 border-2 
                        border-green-600 text-green-700 font-semibold rounded-xl hover:shadow-2xl transition-colors">
                    <i class="fa-brands fa-whatsapp"></i>
                    Scrie pe WhatsApp
                    </a>
                </div>
                </li>
            </ul>
        </div>
    </aside>
</header>