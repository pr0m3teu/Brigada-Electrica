---
import facebookPng from "../assets/png/facebook.png"
import instaPng from "../assets/png/instagram.png"
import tiktokPng from "../assets/png/tiktok.png"
import phonePng from "../assets/png/phone.png"
import whatsappPng from "../assets/png/whatsapp.png"
import emailPng from "../assets/png/email.png"
import locationSvg from "../assets/svg/location.svg"


const links = {
  telefon: "0740 543 785",
  telefonHref: "tel:+40740543785",
  whatsapp: "https://wa.me/40740543785",
  whatsappTextHero: "https://wa.me/40740543785?text=Salut!%20Vreau%20o%20ofert%C4%83%20pentru%20cas%C4%83%20smart%20%C3%AEn%20Ia%C8%99i",
  email: "brigada.electrica.is@gmail.com",
  facebook: "https://www.facebook.com/brigadaelectrica",
  instagram: "https://www.instagram.com/brigadaelectrica",
  tiktok: "https://www.tiktok.com/@brigada.electrica"
}

const year = (new Date().getFullYear()).toString();

---
<footer class="border-t-4 border-main-gold px-6 py-5 bg-main-blue grid lg:grid-cols-3 grid-rows-1">
    <!-- Brigada Electrica -->
    <div class="md:pr-10 lg:pr-16">
    <h4 class="text-2xl font-semibold text-main-white">Brigada Electrică</h4>
    <p class="text-main-gray mt-2 mb-4">
        Puterea Siguranței, Energia Viitorului
    </p>

    <p class="leading-relaxed text-sm font-light text-main-gray mb-4">
        Siguranță și eficiență în instalații electrice interioare și exterioare.
        Oferim proiectare, execuție, modificări și reparații pentru locuințe, spații comerciale și industriale.
    </p>

    <div class="flex content-center my-2">
        <a href={ links.facebook }>
        <img src={ facebookPng.src } alt="facebook" loading="lazy" class="w-8 mr-1.5">
        </a>
        <a href={ links.instagram }>
        <img src={ instaPng.src } alt="instagram" loading="lazy" class="w-8 mr-1.5">
        </a>
        <a href={ links.tiktok }>
        <img src={ tiktokPng.src } alt="tiktok" loading="lazy" class="w-8 mr-1.5">
        </a>
    </div>
    </div>

    <!-- Linkuri rapide -->
    <div class="mt-4 lg:mt-0">
        <h4 class="text-xl text-main-white font-semibold mb-3">Link-uri rapide</h4>
        <ul class="text-main-white">
        <li class="link-rapid"><a id="home-link" href="/"> Acasă </a></li>
        <li class="link-rapid"><a id="servicii-link" href="servicii.html"> Servicii </a></li>
        <li class="link-rapid"><a href="contact.html"> Contact </a></li>
        </ul>
    </div>
    
    <!-- Contact -->
    <div id="contact-footer" class="mt-4 lg:mt-0">
    <h4 class="text-xl text-main-white font-semibold mb-3">Contact</h4>
    <ul class="text-main-white">
        <li class="mb-2 text-main-gray flex content-center">
        <img src={phonePng.src} alt="telefon" loading="lazy" class="w-6">
        <a href={links.telefonHref} class="text-md ml-1.5">{ links.telefon }</a>
        </li>

        <li class="mb-2 text-main-gray flex content-center">
        <img src={whatsappPng.src} alt="whatsapp" loading="lazy" class="w-6">
        <a href={links.whatsapp} target="_blank" rel="noopener" class="text-md ml-1.5">Whatsapp</a>
        </li>

        <li class="mb-2 text-main-gray flex content-center">
        <img src={emailPng.src} alt="e-mail" loading="lazy" class="w-6">
        <a href={`mailto:${links.email}`} class="text-md ml-1.5">{ links.email }</a>
        </li>
        <li class="text-main-gray flex content-center">
        <img src={locationSvg.src} alt="locatie" loading="lazy" class="w-6">
        <p class="text-md ml-1.5">Județul Iași</p>
        </li>
    </ul>
    </div>
    <div class="border-t lg:col-span-3 border-white/10 mt-4">
    <p class="text-center text-main-white text-xs lg:text-sm pt-4">
        © <span id="year">{year}</span> Brigada Electrică. Toate drepturile rezervate.
    </p>
    </div>
</footer>