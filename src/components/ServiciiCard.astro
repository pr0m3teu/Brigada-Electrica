---
import checkPng from "../assets/png/check.png"
import { Image } from "astro:assets"


interface Props {
    benefits?: string[]
}

const {benefits } = Astro.props

---
<div class="py-6 px-6 rounded-xl shadow-2xl flex flex-col h-full lg:py-10">
    <div class="flex-1">
        
        <slot name="icon"/>
        <slot name="title"/>
        <slot name="description"/>

        <ul class="ml-1">
            {benefits?.map((benefit) => ( 
                <li class="li-servicii-section">
                    <Image src={checkPng} alt="bifa" loading="lazy" class="w-5 h-5 mr-2"/>
                    <p class="p-li-servicii-section">{benefit}</p>
                </li>))}
        </ul>

        
          <!-- <button class="text-main-blue bg-secondary-yellow 
            mx-auto self-center py-2.5 px-2.5 text-xl w-5/6 h-fit rounded-full 
            flex items-center justify-center btn-primary
            cursor-pointer">
            <span> Cere o intervenție </span>      
          </button> -->
    </div>
</div>